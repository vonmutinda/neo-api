# =============================================================================
# Neobank API Configuration
# Copy to .env and fill in your values.
# =============================================================================

# ------------- Environment ---------------------------------------------------
# "development", "staging", or "production"
ENV=development

# ------------- Server --------------------------------------------------------
LISTEN_ADDR=:8080
LOG_LEVEL=info

# ------------- PostgreSQL ----------------------------------------------------
DATABASE_URL=postgres://neobank:neobank@localhost:5432/neobank?sslmode=disable

# ------------- Formance Ledger -----------------------------------------------
FORMANCE_URL=http://localhost:3068
FORMANCE_LEDGER_NAME=neobank
FORMANCE_ACCOUNT_PREFIX=neo
FORMANCE_CLIENT_ID=
FORMANCE_CLIENT_SECRET=

# ------------- JWT Authentication --------------------------------------------
# Leave empty for dev-mode (raw user ID as bearer token).
# REQUIRED in production (ENV=production).
JWT_SECRET=
JWT_ISSUER=neobank
JWT_AUDIENCE=neobank-api

# ------------- Rate Limiting -------------------------------------------------
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=30

# ------------- CORS ----------------------------------------------------------
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ------------- EthSwitch (external payments) ---------------------------------
ETHSWITCH_BASE_URL=
ETHSWITCH_CERT_PATH=
ETHSWITCH_KEY_PATH=
ETHSWITCH_CA_PATH=
ETHSWITCH_SFTP_PATH=/data/clearing

# ------------- Fayda eKYC ---------------------------------------------------
FAYDA_BASE_URL=
FAYDA_API_KEY=
FAYDA_PARTNER_ID=

# ------------- Telegram Bot -------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
