        { "name": "X-Request-Id", "value": "{% uuid 'v4' %}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"faydaFin\": \"123456789012\"\n}"
      },
      "parameters": []
    },
